# TMS credentials are NO LONGER required by the bot (cookies are used instead).
# Run `npm run capture-cookies` once to log in manually and save your session.
# These variables are kept here ONLY for reference / future use.
# TMS_USERNAME=your-tms-email@example.com
# TMS_PASSWORD=your-tms-password

# Optional: Google Chat webhook URL for bot lifecycle and critical-error alerts.
# Leave empty to disable notifications. Get the full URL (with key and token query
# params) from the Google Chat space "Manage webhooks" panel.
GOOGLE_CHAT_WEBHOOK_URL=

# Optional: a SEPARATE Google Chat space for low-signal diagnostics so they don't
# clutter the production channel — currently the zero-scan / possible-selector-drift
# warning, plus card previews (scripts/preview-card.ts). Leave empty to log-only.
GOOGLE_CHAT_TEST_WEBHOOK_URL=
