{
  "name": "binance-translation-bot",
  "version": "0.1.0",
  "description": "Auto-Assign Bot for translationtms.com (lo-LA / km-KH)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "playwright test",
    "typecheck": "tsc --noEmit",
    "check-config": "tsx src/index.ts --check-config",
    "smoke": "tsx scripts/smoke.ts",
    "capture-cookies": "tsx scripts/capture-cookies.ts",
    "service:install": "npm run build && node scripts/install-windows-service.js install",
    "service:uninstall": "node scripts/install-windows-service.js uninstall"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.6.2",
    "playwright": "^1.49.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.5",
    "node-windows": "^1.0.0-beta.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
