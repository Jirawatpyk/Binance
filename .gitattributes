# Normalize line endings. Without this, a clone on a machine with
# core.autocrlf=true could check out shell scripts with CRLF, which breaks
# them on the Linux VPS ("bad interpreter: /usr/bin/env bash^M").
* text=auto

# Files that MUST be LF regardless of host — they run on the Linux deploy host.
*.sh        text eol=lf
*.service   text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
